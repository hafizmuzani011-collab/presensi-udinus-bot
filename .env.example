# Konfigurasi bot - rename ke .env dan isi credentials Anda.
# JANGAN commit file .env ke repository!

# ==== Telegram ====
# Dapatkan dari @BotFather di Telegram (/newbot command)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ==== Admin (RECOMMENDED — security) ====
# Chat ID admin yang otomatis punya akses (bootstrap). 
# Dapatkan dari @userinfobot di Telegram. Kosongkan untuk legacy auto-add.
ADMIN_CHAT_ID=

# ==== Display Names (optional, default "Hafizh" / "Azfa") ====
NAMA_SAYA=Hafizh
NAMA_PACAR=Azfa

# ==== Kulino ====
# Login untuk akun Kulino (kulino.dinus.ac.id)
# Akun Hafizh
KULINO_SAYA_NIM=a22xxxxxxxx
KULINO_SAYA_PASS=your_kulino_password

# Akun Azfa (pacar)
KULINO_PACAR_NIM=a11xxxxxxxx
KULINO_PACAR_PASS=your_kulino_password

# ==== MHS / SiAdin ====
# Login untuk akademik (mhs.dinus.ac.id) - jadwal & presensi online
# Akun Hafizh (NIM dengan format A22.2025.XXXXX)
MHS_SAYA_NIM=A22.2025.xxxxx
MHS_SAYA_PASS=your_mhs_password

# Akun Azfa
MHS_PACAR_NIM=A11.2024.xxxxx
MHS_PACAR_PASS=your_mhs_password

# ==== Dashboard ====
# Token akses dashboard web (http://localhost:8787).
# WAJIB diisi. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASH_TOKEN=YOUR_SECURE_TOKEN_HERE

# ==== LLM (opsional) ====
# Untuk smart reply / fallback extraction. Kosongkan jika tidak dipakai.
CLAUDEFIRE_API_KEY=
LLM_MODEL=deepseek-v4-flash-free
