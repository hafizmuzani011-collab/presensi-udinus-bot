# Konfigurasi bot - isi dengan credentials Anda, lalu rename file ini menjadi .env
# JANGAN commit file .env ke repository!

# Telegram (dapatkan dari @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Kulino - Hafizh
KULINO_SAYA_NIM=YOUR_NIM
KULINO_SAYA_PASS=YOUR_PASSWORD

# Kulino - Azfa
KULINO_PACAR_NIM=YOUR_NIM
KULINO_PACAR_PASS=YOUR_PASSWORD

# MHS/SiAdin - Hafizh
MHS_SAYA_NIM=YOUR_NIM
MHS_SAYA_PASS=YOUR_PASSWORD

# MHS/SiAdin - Azfa
MHS_PACAR_NIM=YOUR_NIM
MHS_PACAR_PASS=YOUR_PASSWORD

# Dashboard auth token (WAJIB diisi! jangan pakai default)
DASH_TOKEN=YOUR_SECURE_TOKEN_HERE

# LLM (optional)
CLAUDEFIRE_API_KEY=
LLM_MODEL=deepseek-v4-flash-free
